%% Erlang `ssl` application defaults loaded into the rebar3 BEAM via
%% `ERL_FLAGS="-config config/rebar3_ssl"`.
%%
%% Without these defaults, the rebar3 hex client on OTP 29 RC3 fails
%% the TLS handshake to hex.pm on `/packages/<name>` paths. The
%% handshake completes on `/`, `/names`, `/versions` (and curl works
%% on every path), so it isn't a cert-chain problem — it's Fastly's
%% edge rejecting OTP 29's TLS 1.3 client fingerprint on the package
%% endpoints. Fix is landing in OTP 29 RC4.
%%
%% Workaround: pin TLS 1.2 + disable `middlebox_comp_mode` (TLS
%% 1.3-only option that defaults `true` and is incompatible with a
%% 1.2 pin). The cacertfile path is the standard Ubuntu/Debian system
%% CA bundle (used on the GitHub Actions ubuntu-24.04 runner).
%%
%% Loaded via ERL_FLAGS so it affects ONLY the rebar3 BEAM, not the
%% application's own ssl listeners.
[
    {ssl, [
        {cacertfile, "/etc/ssl/certs/ca-certificates.crt"},
        {middlebox_comp_mode, false},
        {versions, ['tlsv1.2']}
    ]}
].
