%% Logger config for the test profile. Disables the default console
%% handler so deliberately-triggered crash paths in tests (handler-
%% crash → 500, eaddrinuse listener, malformed-TLS bytes, etc.) don't
%% spew CRASH/ERROR/NOTICE reports onto the precommit log. Real test
%% failures still surface via eunit/CT's own assertion reporting.
[
    {kernel, [
        {logger_level, critical},
        {logger, [{handler, default, undefined}]}
    ]}
].
