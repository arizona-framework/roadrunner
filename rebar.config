{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec,
    warn_export_vars,
    warn_unused_import,
    warn_obsolete_guard
]}.

{deps, [
    {telemetry, "1.4.1"}
]}.

{project_plugins, [erlfmt]}.

{erlfmt, [
    write,
    {files, [
        "rebar.config",
        "src/*.{erl,hrl,app.src}",
        "test/*.{erl,hrl}"
    ]}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all, nowarn_missing_spec, {d, 'PROPER'}]},
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {deps, [
            {proper, {git, "https://github.com/proper-testing/proper.git", {tag, "v1.5.0"}}},
            %% Used only by `scripts/bench_vs_cowboy.escript` so we can spin
            %% up a cowboy listener in a peer BEAM and measure roadrunner's
            %% throughput against the obvious incumbent. Test-profile-only
            %% to keep the production dep list at one entry (telemetry).
            {cowboy, "2.14.2"}
        ]}
    ]}
]}.

{eunit_opts, [verbose]}.
{cover_enabled, true}.
{cover_opts, [verbose]}.
{cover_export_enabled, true}.
{dialyzer, [
    {warnings, [unknown, unmatched_returns, error_handling]},
    {plt_apps, top_level_deps},
    {plt_extra_apps, [ssl, public_key, crypto]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{shell, [
    {apps, [roadrunner]}
]}.

{alias, [
    {precommit, [
        {fmt, "--check"},
        compile,
        xref,
        dialyzer,
        {eunit, "--cover"},
        {ct, "--cover"},
        {cover, "--verbose --min_coverage=100"}
    ]}
]}.
